# ─────────────────────────────────────────────────────────────
# Copia este archivo como ".env" y pega tus llaves reales.
# NUNCA compartas el archivo .env ni lo subas a internet.
# ─────────────────────────────────────────────────────────────

# Llave de Apify (para traer los posts de Instagram).
# La obtienes en https://console.apify.com/account/integrations
APIFY_TOKEN=

# Llave de Anthropic / Claude (para leer los captions).
# La obtienes en https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Modelo de Claude para extraer datos de los captions (barato y rápido).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
